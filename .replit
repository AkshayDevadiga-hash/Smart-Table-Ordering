modules = ["web", "nodejs-20", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/backend run dev & PORT=5000 API_URL=http://localhost:8080 pnpm --filter @workspace/frontend run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=8080 node backend/dist/index.mjs & PORT=5000 API_URL=http://localhost:8080 node frontend/server.js"]
build = ["bash", "-c", "npm install -g pnpm && pnpm install && pnpm --filter @workspace/backend run build"]
