PORT=5000
# Neon (or any Postgres): include ?sslmode=require for Neon.
DATABASE_URL=postgresql://user:pass@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_PASSWORD=admin1234
KITCHEN_PASSWORD=kitchen1234
# Comma-separated origins for CORS (production Pages URL + preview URLs if needed).
CLIENT_URL=http://localhost:3000
LOG_LEVEL=info
